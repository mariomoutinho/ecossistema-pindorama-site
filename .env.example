# ============================================================
# .env.example — variáveis de ambiente do Ecossistema Pindorama
# Copie para .env (ignorado pelo Git) e preencha em DEV, ou defina
# estas variáveis no painel/ambiente do servidor em produção.
# NÃO inclua valores reais de senha/segredo neste arquivo de exemplo.
# ============================================================

# --- Provisionamento do terapeuta inicial (área restrita) ---
# Usadas apenas pelo script terapeutas/bin/provisionar-terapeuta.php.
# Após provisionar, remova a senha do ambiente.
INITIAL_THERAPIST_NAME=
INITIAL_THERAPIST_EMAIL=
INITIAL_THERAPIST_PASSWORD=

# --- Administrador inicial (gestão da equipe) ---
# O bootstrap promove este e-mail ao perfil 'admin' UMA vez por ambiente
# (idempotente, sem duplicar). Opcional: se omitido, usa o admin inicial
# padrão do projeto (luizmariomoutinho1@gmail.com / "Luiz"). Não é segredo —
# é apenas um e-mail; a senha continua vindo do provisionamento/redefinição.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_NAME=

# --- Envio de e-mail da área restrita ---
# Transporte: mail (padrão) | smtp | log (apenas DEV; grava .eml em data/)
TERAP_MAIL_TRANSPORT=mail
TERAP_MAIL_FROM=
TERAP_MAIL_FROM_NAME=

# Necessárias apenas quando TERAP_MAIL_TRANSPORT=smtp
TERAP_SMTP_HOST=
TERAP_SMTP_PORT=587
TERAP_SMTP_USER=
TERAP_SMTP_PASS=
TERAP_SMTP_SECURE=tls
TERAP_SMTP_EHLO=localhost
