# ============================================================
# .gitignore — site Ecossistema Pindorama
# ============================================================

# --- Credenciais e configuração local ---
config-db.php
terapeutas/config-mail.php
terapeutas/config-provision.php
.env
.env.*
!.env.example

# --- Backups e importações temporárias (etapa de migração Hostinger) ---
_backup_*/
_hostinger_*/
*.zip
*.zip:Zone.Identifier

# --- Subprojetos fora do escopo deste repositório ---
# pindorama-rpg vai virar repositório próprio
pindorama-rpg/
# script utilitário de teste de conexão (não pertence ao site)
dbtest.php

# --- Dados gerados em runtime ---
data/
*.log

# --- Ferramentas de IDE / sistema operacional ---
.claude/settings.local.json
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- PHP / dependências ---
vendor/
composer.lock

# --- Pindorama RPG (espelho do repo pindoramarpg em pindoramarpg/) ---
# Credenciais e estado runtime do RPG nunca vão para o repositório.
pindoramarpg/config.php
pindoramarpg/config.local.php
pindoramarpg/.env
pindoramarpg/.env.*
pindoramarpg/secrets.*
pindoramarpg/uploads/
# Re-inclui pindoramarpg/data/ — a regra genérica `data/` acima estava
# excluindo dados pré-carregados do RPG (ancestralidades, bestiário, etc.),
# que precisam ser deployados. Os arquivos de estado runtime continuam
# excluídos pelas regras específicas logo abaixo.
!pindoramarpg/data/
pindoramarpg/data/campo-batalha-state*.json
pindoramarpg/data/aventuras/*/cenas.json
pindoramarpg/*.sql
pindoramarpg/*.sql.bak
pindoramarpg/vendor/
pindoramarpg/node_modules/

# --- Ferramentas de desenvolvimento local (nunca publicar) ---
# Modo de pré-visualização local da agenda (login fictício sob php -S):
terapeutas/preview-local.php
# Scripts para subir o servidor PHP local:
start-local.sh
start-local.ps1
start-local.bat
